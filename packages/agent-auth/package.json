{
  "name": "@better-auth/agent-auth",
  "version": "0.4.5",
  "description": "Agent Auth Protocol server plugin for Better Auth — agent identity, registration, and capability-based authorization",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/better-auth/agent-auth",
    "directory": "packages/agent-auth"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    },
    "./openapi": {
      "import": {
        "types": "./dist/openapi.d.ts",
        "default": "./dist/openapi.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "better-call": "1.3.2",
    "jose": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/core": "1.5.4",
    "@better-auth/passkey": "1.5.4",
    "@better-auth/utils": "^0.3.0",
    "@types/node": "^25.3.0",
    "better-auth": "1.5.4",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@better-auth/core": ">=1.4.0",
    "better-auth": ">=1.4.0"
  }
}
