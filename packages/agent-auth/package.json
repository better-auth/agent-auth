{
  "name": "@better-auth/agent-auth",
  "version": "0.1.0",
  "type": "module",
  "description": "AI agent authentication and authorization plugin for Better Auth",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    },
    "./agent-client": {
      "import": {
        "types": "./dist/agent-client.d.ts",
        "default": "./dist/agent-client.js"
      }
    },
    "./mcp-tools": {
      "import": {
        "types": "./dist/mcp-tools.d.ts",
        "default": "./dist/mcp-tools.js"
      }
    },
    "./mcp-storage-fs": {
      "import": {
        "types": "./dist/mcp-storage-fs.d.ts",
        "default": "./dist/mcp-storage-fs.js"
      }
    },
    "./mcp-storage-memory": {
      "import": {
        "types": "./dist/mcp-storage-memory.d.ts",
        "default": "./dist/mcp-storage-memory.js"
      }
    },
    "./mcp-server": {
      "import": {
        "types": "./dist/mcp-server.d.ts",
        "default": "./dist/mcp-server.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@better-auth/core": ">=1.4.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "better-auth": ">=1.4.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@auth/agents": "workspace:*",
    "better-call": "^1.3.2",
    "jose": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/core": "1.5.0-beta.18",
    "@better-auth/utils": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/ciphers": "^1.0.0",
    "@types/node": "^25.3.0",
    "better-auth": "1.5.0-beta.18",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  }
}
