{
  "name": "@auth/agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Client SDK for the Agent Auth Protocol — agent identity, registration, and capability-based authorization",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./tools": {
      "import": {
        "types": "./dist/tools-entry.d.ts",
        "default": "./dist/tools-entry.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "^6.0.0"
  },
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
