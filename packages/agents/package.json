{
  "name": "@auth/agents",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent runtime SDK — keypair management, device auth flow, MCP tools, and MCP server for AI agents",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "auth": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./agent-client": {
      "import": {
        "types": "./dist/agent-client.d.ts",
        "default": "./dist/agent-client.js"
      }
    },
    "./mcp-tools": {
      "import": {
        "types": "./dist/mcp-tools.d.ts",
        "default": "./dist/mcp-tools.js"
      }
    },
    "./mcp-storage-fs": {
      "import": {
        "types": "./dist/mcp-storage-fs.d.ts",
        "default": "./dist/mcp-storage-fs.js"
      }
    },
    "./mcp-storage-memory": {
      "import": {
        "types": "./dist/mcp-storage-memory.d.ts",
        "default": "./dist/mcp-storage-memory.js"
      }
    },
    "./ai": {
      "import": {
        "types": "./dist/ai.d.ts",
        "default": "./dist/ai.js"
      }
    },
    "./mcp-server": {
      "import": {
        "types": "./dist/mcp-server.d.ts",
        "default": "./dist/mcp-server.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "jose": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/utils": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/ciphers": "^1.0.0",
    "@types/node": "^25.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0"
  }
}
