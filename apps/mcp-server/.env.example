# Postgres connection string (Vercel Postgres, Neon, or any Postgres)
POSTGRES_URL=postgresql://postgres:postgres@localhost:54323/agentauth_mcp

# Public URL of this deployment
BETTER_AUTH_URL=http://localhost:3400

# Agent Auth registry URL for provider discovery (optional)
AGENT_AUTH_REGISTRY_URL=http://localhost:4200

# Host display name shown to providers
AGENT_AUTH_HOST_NAME=Agent Auth MCP Server
