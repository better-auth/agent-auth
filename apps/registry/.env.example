# Postgres connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:54323/postgres

# Public URL of this deployment
BETTER_AUTH_URL=http://localhost:4200

# Better Auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# GitHub OAuth (for social sign-in)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Registry admin key for provider management
REGISTRY_ADMIN_KEY=change-me-in-production

# Host display name shown to providers via MCP
AGENT_AUTH_HOST_NAME=Agent Auth Registry
